{
  "manifest_version": 3,
  "name": "Blazor Dev Tools",
  "version": "1.0.0",
  "description": "Inspect Blazor components, parameters, and dependency injection from Chrome DevTools.",
  "devtools_page": "devtools.html",
  "permissions": ["storage"],
  "background": {
    "service_worker": "dist/scripts/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Blazor Dev Tools",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["dist/scripts/content.js"],
      "run_at": "document_start"
    }
  ]
}
