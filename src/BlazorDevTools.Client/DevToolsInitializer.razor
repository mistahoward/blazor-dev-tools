@using BlazorDevTools.Client.Services
@inject IBlazorDevToolsService DevTools

@code {
    private const int MaxInitAttempts = 10;
    private int _attempts;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!DevTools.IsEnabled)
        {
            return;
        }

        if (!DevTools.IsInitialized && _attempts < MaxInitAttempts)
        {
            _attempts++;
            await DevTools.InitializeAsync(this);

            if (!DevTools.IsInitialized)
            {
                StateHasChanged();
                return;
            }
        }

        if (DevTools.IsInitialized)
        {
            DevTools.RequestRefresh();
        }
    }
}
